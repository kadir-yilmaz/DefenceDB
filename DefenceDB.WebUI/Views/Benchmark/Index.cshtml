        <!-- Full Screen JSON Modal -->
        <div class="modal fade" id="jsonFullscreenModal" tabindex="-1" aria-labelledby="jsonFullscreenModalLabel" aria-hidden="true" style="backdrop-filter: blur(12px); z-index: 1060;">
            <div class="modal-dialog modal-fullscreen modal-dialog-scrollable">
                <div class="modal-content" style="background: #020617; border: 1px solid rgba(148, 163, 184, 0.15);">
                    <div class="modal-header" style="border-bottom: 1px solid rgba(148, 163, 184, 0.1);">
                        <h5 class="modal-title text-white" id="jsonFullscreenModalLabel">
                            <i class="bi bi-braces text-warning me-2"></i>Detaylı JSON Verisi
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <pre class="m-0 text-success" id="modalJsonRawPre" style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; line-height: 1.5; white-space: pre-wrap; word-break: break-all;"></pre>
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid rgba(148, 163, 184, 0.1);">
                        <button type="button" class="bench-btn" style="background: rgba(148, 163, 184, 0.1); color: #cbd5e1; border: 1px solid rgba(148, 163, 184, 0.2);" onclick="copyJsonTextModal()">
                            <i class="bi bi-clipboard me-1"></i> Kopyala
                        </button>
                        <button type="button" class="bench-btn bench-btn-primary" data-bs-dismiss="modal">Kapat</button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        // ── State ─────────────────────────────────────────
        const history = [];
        const sparkData = {
            GetAllProducts: [],
            TextSearch: [],
            CacheTest: []
        };
        let isBattleRunning = false;

        // ── Chart Setup ────────────────────────────────────
        const ctx = document.getElementById('benchmarkChart').getContext('2d');
        const benchChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: [],
                datasets: [
                    {
                        label: 'SQL Server TPT (ms)',
                        data: [],
                        backgroundColor: 'rgba(96, 165, 250, 0.7)',
                        borderColor: '#60a5fa',
                        borderWidth: 1,
                        borderRadius: 6,
                        barPercentage: 0.7,
                    },
                    {
                        label: 'SQL Read Model (ms)',
                        data: [],
                        backgroundColor: 'rgba(52, 211, 153, 0.7)',
                        borderColor: '#34d399',
                        borderWidth: 1,
                        borderRadius: 6,
                        barPercentage: 0.7,
                    },
                    {
                        label: 'Elasticsearch (ms)',
                        data: [],
                        backgroundColor: 'rgba(167, 139, 250, 0.7)',
                        borderColor: '#a78bfa',
                        borderWidth: 1,
                        borderRadius: 6,
                        barPercentage: 0.7,
                    },
                    {
                        label: 'Cache Cold (ms)',
                        data: [],
                        backgroundColor: 'rgba(244, 63, 94, 0.7)',
                        borderColor: '#f43f5e',
                        borderWidth: 1,
                        borderRadius: 6,
                        barPercentage: 0.7,
                    },
                    {
                        label: 'Cache Hot (ms)',
                        data: [],
                        backgroundColor: 'rgba(251, 191, 36, 0.7)',
                        borderColor: '#fbbf24',
                        borderWidth: 1,
                        borderRadius: 6,
                        barPercentage: 0.7,
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 800,
                    easing: 'easeOutQuart'
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleFont: { family: "'Inter', sans-serif", weight: '600' },
                        bodyFont: { family: "'JetBrains Mono', monospace" },
                        borderColor: 'rgba(148, 163, 184, 0.2)',
                        borderWidth: 1,
                        cornerRadius: 8,
                        padding: 12,
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + ' ms';
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: { color: '#94a3b8', font: { family: "'Inter', sans-serif", size: 11 } },
                        grid: { color: 'rgba(148, 163, 184, 0.06)' }
                    },
                    y: {
                        beginAtZero: true,
                        ticks: {
                            color: '#94a3b8',
                            font: { family: "'JetBrains Mono', monospace", size: 11 },
                            callback: function(value) { return value + ' ms'; }
                        },
                        grid: { color: 'rgba(148, 163, 184, 0.06)' }
                    }
                }
            }
        });

        function addToChart(label, sqlMs, sqlFlatMs, esMs, cacheColdMs, cacheHotMs) {
            benchChart.data.labels.push(label);
            benchChart.data.datasets[0].data.push(sqlMs || 0);
            benchChart.data.datasets[1].data.push(sqlFlatMs || 0);
            benchChart.data.datasets[2].data.push(esMs || 0);
            benchChart.data.datasets[3].data.push(cacheColdMs || 0);
            benchChart.data.datasets[4].data.push(cacheHotMs || 0);
            benchChart.update();
        }

        // ── Console Logger ─────────────────────────────────
        function logToConsole(message, type = 'info') {
            const consoleBox = document.getElementById('consoleBox');
            if (!consoleBox) return;
            const timeStr = new Date().toLocaleTimeString('tr-TR');
            const logLine = document.createElement('div');
            logLine.className = `console-line ${type}`;
            logLine.textContent = `[${timeStr}] [${type.toUpperCase()}] ${message}`;
            consoleBox.appendChild(logLine);
            consoleBox.scrollTop = consoleBox.scrollHeight;
        }

        function clearConsole() {
            const consoleBox = document.getElementById('consoleBox');
            if (consoleBox) {
                consoleBox.innerHTML = `<div class="console-line text-muted">[${new Date().toLocaleTimeString('tr-TR')}] [System] Konsol temizlendi. Yeni testler bekleniyor...</div>`;
            }
        }

        // ── Live Diagram Animations ────────────────────────
        function animateDiagramPath(tech) {
            const paths = ['client-controller', 'controller-sql', 'controller-flat', 'controller-cache', 'controller-es'];
            const nodes = ['client', 'controller', 'sql', 'flat', 'cache', 'es'];
            
            // Clear all active classes/attributes
            paths.forEach(p => {
                const pathEl = document.getElementById('flow-' + p);
                const dotEl = document.getElementById('dot-' + p);
                if (pathEl) {
                    pathEl.setAttribute('stroke', '#334155');
                    pathEl.setAttribute('stroke-width', '3');
                }
                if (dotEl) {
                    dotEl.setAttribute('opacity', '0');
                }
            });
            nodes.forEach(n => {
                const nodeEl = document.getElementById('node-' + n);
                if (nodeEl) {
                    nodeEl.querySelector('rect').setAttribute('stroke-width', '1.5');
                    nodeEl.querySelector('rect').setAttribute('filter', 'none');
                }
            });

            // Activate standard paths
            document.getElementById('flow-client-controller')?.setAttribute('stroke', '#0ea5e9');
            document.getElementById('dot-client-controller')?.setAttribute('opacity', '1');
            document.getElementById('node-client')?.querySelector('rect').setAttribute('stroke-width', '3');
            document.getElementById('node-controller')?.querySelector('rect').setAttribute('stroke-width', '3');

            let targetNode = '';
            let targetPath = '';
            let color = '';

            if (tech === 'sql') {
                targetNode = 'sql';
                targetPath = 'controller-sql';
                color = '#3b82f6';
            } else if (tech === 'flat') {
                targetNode = 'flat';
                targetPath = 'controller-flat';
                color = '#10b981';
            } else if (tech === 'cache') {
                targetNode = 'cache';
                targetPath = 'controller-cache';
                color = '#fbbf24';
            } else if (tech === 'es') {
                targetNode = 'es';
                targetPath = 'controller-es';
                color = '#a855f7';
            }

            if (targetNode) {
                const nEl = document.getElementById('node-' + targetNode);
                if (nEl) {
                    nEl.querySelector('rect').setAttribute('stroke-width', '3.5');
                    nEl.querySelector('rect').setAttribute('stroke', color);
                }
            }
            if (targetPath) {
                const pEl = document.getElementById('flow-' + targetPath);
                if (pEl) {
                    pEl.setAttribute('stroke', color);
                    pEl.setAttribute('stroke-width', '4');
                }
                const dEl = document.getElementById('dot-' + targetPath);
                if (dEl) {
                    dEl.setAttribute('opacity', '1');
                }
            }

            // Sync flow animation on sql run
            if (tech === 'sql') {
                const syncPath = document.getElementById('flow-sql-sync');
                if (syncPath) {
                    syncPath.setAttribute('stroke', '#10b981');
                    setTimeout(() => {
                        syncPath.setAttribute('stroke', '#475569');
                    }, 2000);
                }
            }
        }

        // ── Counting Animation ─────────────────────────────
        function animateValue(el, start, end, suffix, duration) {
            const range = end - start;
            const startTime = performance.now();
            function step(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = start + range * eased;
                if (suffix === 'x') {
                    el.textContent = current.toFixed(0) + 'x';
                } else if (suffix === 'ms') {
                    el.textContent = current.toFixed(1) + ' ms';
                } else {
                    el.textContent = Math.round(current);
                }
                if (progress < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
        }

        // ── Update Stats ──────────────────────────────────
        function updateStats() {
            document.getElementById('stat-totalRuns').textContent = history.length;

            if (history.length === 0) {
                document.getElementById('stat-avgSql').textContent = '—';
                document.getElementById('stat-fastestTech').textContent = '—';
                document.getElementById('stat-speedGain').textContent = '—';
                document.getElementById('hs-total').textContent = '0';
                document.getElementById('hs-avgSql').textContent = '—';
                return;
            }

            const avgSql = history.reduce((s, h) => s + h.sqlTimeMs, 0) / history.length;
            const avgEl = document.getElementById('stat-avgSql');
            animateValue(avgEl, 0, avgSql, 'ms', 600);

            let fastest = { name: 'SQL TPT', ms: Infinity };
            history.forEach(h => {
                if (h.sqlTimeMs < fastest.ms) fastest = { name: 'SQL TPT', ms: h.sqlTimeMs };
                if (h.sqlReadModelTimeMs != null && h.sqlReadModelTimeMs < fastest.ms) fastest = { name: 'Read Model', ms: h.sqlReadModelTimeMs };
                if (h.esTimeMs != null && h.esTimeMs < fastest.ms) fastest = { name: 'ES', ms: h.esTimeMs };
                if (h.cacheHotMs != null && h.cacheHotMs < fastest.ms) fastest = { name: 'Cache', ms: h.cacheHotMs };
            });
            document.getElementById('stat-fastestTech').textContent = fastest.name;

            const cacheRuns = history.filter(h => h.cacheHotMs != null && h.cacheHotMs > 0);
            if (cacheRuns.length > 0) {
                const lastCache = cacheRuns[cacheRuns.length - 1];
                const ratio = Math.round(lastCache.sqlTimeMs / lastCache.cacheHotMs);
                const gainEl = document.getElementById('stat-speedGain');
                animateValue(gainEl, 0, ratio, 'x', 800);
            } else {
                document.getElementById('stat-speedGain').textContent = '—';
            }

            document.getElementById('hs-total').textContent = history.length;
            document.getElementById('hs-avgSql').textContent = avgSql.toFixed(1) + ' ms';
        }

        // ── Sparklines ────────────────────────────────────
        function drawSparkline(canvasId, data, color) {
            const canvas = document.getElementById(canvasId);
            if (!canvas || data.length < 2) return;
            const ctx2 = canvas.getContext('2d');
            const w = canvas.width = 60;
            const h = canvas.height = 24;
            ctx2.clearRect(0, 0, w, h);

            const max = Math.max(...data);
            const min = Math.min(...data);
            const range = max - min || 1;
            const step = w / (data.length - 1);

            ctx2.beginPath();
            ctx2.strokeStyle = color;
            ctx2.lineWidth = 1.5;
            ctx2.lineJoin = 'round';

            data.forEach((val, i) => {
                const x = i * step;
                const y = h - 2 - ((val - min) / range) * (h - 4);
                if (i === 0) ctx2.moveTo(x, y);
                else ctx2.lineTo(x, y);
            });
            ctx2.stroke();

            ctx2.lineTo((data.length - 1) * step, h);
            ctx2.lineTo(0, h);
            ctx2.closePath();
            const grad = ctx2.createLinearGradient(0, 0, 0, h);
            grad.addColorStop(0, color.replace(')', ', 0.2)').replace('rgb', 'rgba'));
            grad.addColorStop(1, 'rgba(0,0,0,0)');
            ctx2.fillStyle = grad;
            ctx2.fill();
        }

        // ── History Table & Expandable Details ─────────────
        function toggleHistoryDetail(num) {
            const el = document.getElementById('history-detail-' + num);
            if (el) {
                el.classList.toggle('d-none');
            }
        }

        function addToHistory(data) {
            const entry = {
                num: history.length + 1,
                scenario: data.scenario,
                sqlTimeMs: data.sqlTimeMs,
                sqlReadModelTimeMs: data.sqlReadModelTimeMs,
                esTimeMs: data.esTimeMs,
                cacheColdMs: data.cacheColdMs,
                cacheHotMs: data.cacheHotMs,
                count: data.sqlCount || data.esCount || data.cacheCount || 0,
                time: new Date().toLocaleTimeString('tr-TR')
            };

            const times = [];
            times.push({ name: 'SQL TPT', ms: entry.sqlTimeMs });
            if (entry.sqlReadModelTimeMs != null) times.push({ name: 'Read Model', ms: entry.sqlReadModelTimeMs });
            if (entry.esTimeMs != null) times.push({ name: 'ES', ms: entry.esTimeMs });
            if (entry.cacheColdMs != null) times.push({ name: 'Cache Cold', ms: entry.cacheColdMs });
            if (entry.cacheHotMs != null) times.push({ name: 'Cache Hot', ms: entry.cacheHotMs });
            times.sort((a, b) => a.ms - b.ms);
            entry.winner = times[0]?.name || '—';
            entry.slowest = times[times.length - 1]?.name || '—';

            history.push(entry);

            const scenarioKey = data.scenario.includes('Tüm') ? 'GetAllProducts' : data.scenario.includes('Metin') ? 'TextSearch' : 'CacheTest';
            sparkData[scenarioKey].push(entry.sqlTimeMs);
            if (sparkData[scenarioKey].length > 8) sparkData[scenarioKey].shift();
            drawSparkline('spark-' + scenarioKey, sparkData[scenarioKey], 'rgb(96, 165, 250)');

            const meta = document.getElementById('meta-' + scenarioKey);
            if (meta) {
                meta.querySelector('span').textContent = 'Son: ' + entry.time;
            }

            renderHistory();
            updateStats();
        }

        function renderHistory() {
            const body = document.getElementById('historyBody');
            if (history.length === 0) {
                body.innerHTML = `<tr><td colspan="10" class="history-empty"><i class="bi bi-inbox me-1"></i> Henüz test çalıştırılmadı.</td></tr>`;
                return;
            }

            body.innerHTML = history.slice().reverse().map(h => {
                function cellClass(name, ms) {
                    if (ms == null) return '';
                    if (name === h.winner) return 'cell-fastest';
                    if (name === h.slowest) return 'cell-slowest';
                    return '';
                }
                function fmt(ms) { return ms != null ? ms.toFixed(2) + ' ms' : '—'; }

                // Speed bars calculation relative to slowest
                const baseSlow = Math.max(h.sqlTimeMs, h.sqlReadModelTimeMs || 0, h.esTimeMs || 0, h.cacheColdMs || 0, h.cacheHotMs || 0);
                function getPct(ms) {
                    if (!ms) return 0;
                    return Math.max(1, (ms / baseSlow) * 100);
                }

                // Query code segments
                let sqlQuery = "";
                let cqrsQuery = "SELECT Id, Name, CategoryName, ProductType, SpecificPropertiesJson FROM ProductReadModels";
                let cacheQuery = "_cache.TryGetValue(\"benchmark:cache\", out var entry) // local RAM read";
                let esQuery = `POST /defenseproducts/_search \n{ "query": { "match": { "name": "..." } } }`;

                if (h.scenario.includes("Tüm")) {
                    sqlQuery = "SELECT p.Id, p.Name, p.CategoryId, t.ArmorThickness, f.AesaRadarType, ... \nFROM DefenseProducts p \nLEFT JOIN LandVehicles t ON p.Id = t.Id \nLEFT JOIN FighterAircrafts f ON p.Id = f.Id \n-- (22 LEFT JOINs across TPT inheritance)";
                } else if (h.scenario.includes("Metin")) {
                    sqlQuery = "SELECT p.Id, p.Name ... FROM DefenseProducts p \nWHERE LOWER(p.Name) LIKE '%hava%' OR LOWER(p.Description) LIKE '%hava%' \n-- (Heavy string scans on sub-tables)";
                    cqrsQuery = "SELECT Id, Name, SpecificPropertiesJson FROM ProductReadModels \nWHERE LOWER(Name) LIKE '%hava%' OR LOWER(Description) LIKE '%hava%' \n-- (Single Flat table string scan)";
                } else {
                    sqlQuery = "SELECT * FROM DefenseProducts p \nLEFT JOIN Images ... -- (Uncached Database Query)";
                    cqrsQuery = "SELECT * FROM ProductReadModels -- (Flat database check)";
                }

                // Optimization tip
                let optimizationTip = "";
                if (h.winner === 'Cache Hot') {
                    optimizationTip = `<strong>Öneri:</strong> In-Memory Cache Hot bu senaryoda <strong>${(h.sqlTimeMs / h.cacheHotMs).toFixed(0)}x daha hızlı</strong>. Sıkça değişmeyen, yoğun talep gören listeleme sayfaları için Memory Cache kullanımı veritabanını tamamen rahatlatır.`;
                } else if (h.winner === 'Read Model') {
                    optimizationTip = `<strong>Öneri:</strong> SQL Read Model, TPT JOIN patlamasını ortadan kaldırarak performansı <strong>${(h.sqlTimeMs / h.sqlReadModelTimeMs).toFixed(0)}x artırdı</strong>. Bu senaryo için CQRS Flat Table okuması mükemmel bir denge sağlar.`;
                } else if (h.winner === 'ES') {
                    optimizationTip = `<strong>Öneri:</strong> Elasticsearch full-text arama kabiliyeti sayesinde SQL LIKE aramalarına göre <strong>${(h.sqlTimeMs / h.esTimeMs).toFixed(0)}x daha hızlı</strong>. Metin aramalarında ES tercih edilmelidir.`;
                } else if (h.winner === 'Cache Cold') {
                    optimizationTip = `<strong>Öneri:</strong> Cache Cold (Miss) ilk isteği veritabanından/ES'den alıp belleğe yazarken bir kerelik gecikme oluşturur. Sonraki tüm istekler Cache Hot olarak ultra hızlı tamamlanır.`;
                }

                // Performance Tiers
                function getTierBadge(ms) {
                    if (!ms) return '';
                    if (ms < 2) return '<span class="perf-tier tier-s">Tier S (Ultra Fast)</span>';
                    if (ms < 20) return '<span class="perf-tier tier-a">Tier A (Excellent)</span>';
                    if (ms < 100) return '<span class="perf-tier tier-b">Tier B (Good)</span>';
                    return '<span class="perf-tier tier-c">Tier C (Slow)</span>';
                }

                return `
                <tr class="history-row" onclick="toggleHistoryDetail(${h.num})">
                    <td>${h.num} <i class="bi bi-chevron-down ms-1" style="font-size:0.7rem; color:#64748b;"></i></td>
                    <td class="scenario-cell">${h.scenario}</td>
                    <td class="${cellClass('SQL TPT', h.sqlTimeMs)}">${fmt(h.sqlTimeMs)}</td>
                    <td class="${cellClass('Read Model', h.sqlReadModelTimeMs)}">${fmt(h.sqlReadModelTimeMs)}</td>
                    <td class="${cellClass('ES', h.esTimeMs)}">${fmt(h.esTimeMs)}</td>
                    <td class="${cellClass('Cache Cold', h.cacheColdMs)}">${fmt(h.cacheColdMs)}</td>
                    <td class="${cellClass('Cache Hot', h.cacheHotMs)}">${fmt(h.cacheHotMs)}</td>
                    <td style="color: #94a3b8;">${h.count}</td>
                    <td><span class="winner-badge"><i class="bi bi-trophy-fill text-warning"></i> ${h.winner}</span></td>
                    <td style="color: #64748b; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;">${h.time}</td>
                </tr>
                <tr id="history-detail-${h.num}" class="d-none bg-dark-card">
                    <td colspan="10" class="p-3">
                        <div class="detail-container">
                            <div class="detail-grid">
                                <div>
                                    <div class="detail-title"><i class="bi bi-activity text-info"></i> Performans Spektrumu</div>
                                    
                                    <div class="performance-bar-wrap">
                                        <div class="performance-bar-label"><span>SQL Server TPT</span> <span>${fmt(h.sqlTimeMs)} ${getTierBadge(h.sqlTimeMs)}</span></div>
                                        <div class="performance-bar-outer"><div class="performance-bar-inner" style="--bar-color: #3b82f6; width: ${getPct(h.sqlTimeMs)}%;"></div></div>
                                    </div>
                                    
                                    ${h.sqlReadModelTimeMs ? `
                                    <div class="performance-bar-wrap">
                                        <div class="performance-bar-label"><span>SQL Read Model</span> <span>${fmt(h.sqlReadModelTimeMs)} ${getTierBadge(h.sqlReadModelTimeMs)}</span></div>
                                        <div class="performance-bar-outer"><div class="performance-bar-inner" style="--bar-color: #10b981; width: ${getPct(h.sqlReadModelTimeMs)}%;"></div></div>
                                    </div>` : ''}

                                    ${h.esTimeMs ? `
                                    <div class="performance-bar-wrap">
                                        <div class="performance-bar-label"><span>Elasticsearch</span> <span>${fmt(h.esTimeMs)} ${getTierBadge(h.esTimeMs)}</span></div>
                                        <div class="performance-bar-outer"><div class="performance-bar-inner" style="--bar-color: #a855f7; width: ${getPct(h.esTimeMs)}%;"></div></div>
                                    </div>` : ''}

                                    ${h.cacheColdMs ? `
                                    <div class="performance-bar-wrap">
                                        <div class="performance-bar-label"><span>Memory Cache Miss (Cold)</span> <span>${fmt(h.cacheColdMs)} ${getTierBadge(h.cacheColdMs)}</span></div>
                                        <div class="performance-bar-outer"><div class="performance-bar-inner" style="--bar-color: #f43f5e; width: ${getPct(h.cacheColdMs)}%;"></div></div>
                                    </div>` : ''}

                                    ${h.cacheHotMs ? `
                                    <div class="performance-bar-wrap">
                                        <div class="performance-bar-label"><span>Memory Cache Hit (Hot)</span> <span>${fmt(h.cacheHotMs)} ${getTierBadge(h.cacheHotMs)}</span></div>
                                        <div class="performance-bar-outer"><div class="performance-bar-inner" style="--bar-color: #fbbf24; width: ${getPct(h.cacheHotMs)}%;"></div></div>
                                    </div>` : ''}

                                    <div class="recommendation-text mt-3">
                                        ${optimizationTip}
                                    </div>
                                </div>
                                <div>
                                    <div class="detail-title"><i class="bi bi-code-slash text-warning"></i> Arka Plan Sorgu Detayları</div>
                                    
                                    <div class="mb-2">
                                        <span class="battle-label">SQL Server TPT Query (Complex JOINs):</span>
                                        <div class="query-code-block">${sqlQuery}</div>
                                    </div>
                                    
                                    <div class="mb-2">
                                        <span class="battle-label">SQL Read Model Query (CQRS Single Table):</span>
                                        <div class="query-code-block">${cqrsQuery}</div>
                                    </div>
                                    
                                    ${h.esTimeMs ? `
                                    <div class="mb-2">
                                        <span class="battle-label">Elasticsearch Query (JSON REST Request):</span>
                                        <div class="query-code-block">${esQuery}</div>
                                    </div>` : ''}

                                    ${h.cacheHotMs ? `
                                    <div>
                                        <span class="battle-label">In-Memory Cache (RAM Lookup):</span>
                                        <div class="query-code-block">${cacheQuery}</div>
                                    </div>` : ''}
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
                `;
            }).join('');
        }

        function clearHistory() {
            history.length = 0;
            sparkData.GetAllProducts = [];
            sparkData.TextSearch = [];
            sparkData.CacheTest = [];

            benchChart.data.labels = [];
            benchChart.data.datasets.forEach(d => d.data = []);
            benchChart.update();

            renderHistory();
            updateStats();
            logToConsole("Test geçmişi temizlendi.", "info");

            onScenarioChange();
        }

        async function reindex(btn) {
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="bench-spinner"></span> Reindex...';
            btn.disabled = true;
            logToConsole("Elasticsearch veri dizini yeniden indeksleme komutu gönderildi...", "cmd");

            try {
                const resp = await fetch('/Benchmark/Reindex', { method: 'POST' });
                const data = await resp.json();
                displayRawJson(data);
                if (data.success) {
                    logToConsole(`ES Reindex tamamlandı. Süre: ${data.timeMs.toFixed(0)} ms`, "success");
                    alert(`Reindex tamamlandı! Süre: ${data.timeMs.toFixed(0)} ms`);
                    fetchCounts();
                } else {
                    logToConsole("ES Reindex başarısız: " + data.message, "warning");
                    alert(data.message || 'Reindex başarısız');
                }
            } catch (err) {
                logToConsole(`Reindex işleminde hata: ${err.message}`, "warning");
                alert('Reindex hatası: ' + err.message);
            }

            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }

        async function syncReadModels(btn) {
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="bench-spinner"></span> Senkronize ediliyor...';
            btn.disabled = true;
            logToConsole("CQRS Read Model Flat tablosu SQL verileriyle eşitleniyor (Sync)...", "cmd");

            try {
                const resp = await fetch('/Benchmark/SyncReadModels', { method: 'POST' });
                const data = await resp.json();
                displayRawJson(data);
                if (data.success) {
                    logToConsole(`CQRS Read Model eşitlendi! Aktarılan kayıt: ${data.count}. Süre: ${data.timeMs.toFixed(0)} ms`, "success");
                    alert(`Read Model Senkronizasyonu Tamamlandı! \nSüre: ${data.timeMs.toFixed(0)} ms \nAktarılan Kayıt: ${data.count}`);
                    fetchCounts();
                } else {
                    logToConsole("Sync işlemi başarısız.", "warning");
                    alert('Senkronizasyon başarısız');
                }
            } catch (err) {
                logToConsole(`Eşitlemede hata oluştu: ${err.message}`, "warning");
                alert('Senkronizasyon hatası: ' + err.message);
            }

            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }

        // ── Canlı Durum ve Kayıt Sayısı Gösterimi ───────────
        async function fetchCounts() {
            try {
                const resp = await fetch('/Benchmark/GetIndexStatus');
                if (resp.ok) {
                    const data = await resp.json();
                    updateStatusUI(data);
                }
            } catch (err) {
                console.error("Durum bilgileri çekilemedi:", err);
            }
        }

        function updateStatusUI(data) {
            const { esCount, sqlReadModelCount, totalProductsCount } = data;
            
            const statusEsEl = document.getElementById('statusEs');
            if (statusEsEl) {
                if (esCount === 0) {
                    statusEsEl.innerHTML = `<span class="text-danger">⚠️ İndeks Boş (0 / ${totalProductsCount})</span>`;
                } else if (esCount !== totalProductsCount) {
                    statusEsEl.innerHTML = `<span class="text-warning">⚠️ Eksik İndeks (${esCount} / ${totalProductsCount})</span>`;
                } else {
                    statusEsEl.innerHTML = `<span class="text-success">✅ İndekslendi (${esCount} / ${totalProductsCount})</span>`;
                }
            }
            
            const statusReadModelEl = document.getElementById('statusReadModel');
            if (statusReadModelEl) {
                if (sqlReadModelCount === 0) {
                    statusReadModelEl.innerHTML = `<span class="text-danger">⚠️ Tablo Boş (0 / ${totalProductsCount})</span>`;
                } else if (sqlReadModelCount !== totalProductsCount) {
                    statusReadModelEl.innerHTML = `<span class="text-warning">⚠️ Eksik Tablo (${sqlReadModelCount} / ${totalProductsCount})</span>`;
                } else {
                    statusReadModelEl.innerHTML = `<span class="text-success">✅ Eşitlendi (${sqlReadModelCount} / ${totalProductsCount})</span>`;
                }
            }
        }

        // ── JSON Veri Gösterimi ve Modal İşlemleri ───────────
        let lastReceivedJson = null;

        function displayRawJson(data) {
            lastReceivedJson = data;
            document.getElementById('jsonResponseSection').style.display = 'block';
            document.getElementById('jsonRawPre').textContent = JSON.stringify(data, null, 4);
        }

        function openJsonModal() {
            if (!lastReceivedJson) return;
            document.getElementById('modalJsonRawPre').textContent = JSON.stringify(lastReceivedJson, null, 4);
            const myModal = new bootstrap.Modal(document.getElementById('jsonFullscreenModal'));
            myModal.show();
        }

        function copyJsonText() {
            if (!lastReceivedJson) return;
            navigator.clipboard.writeText(JSON.stringify(lastReceivedJson, null, 4));
            alert("JSON verisi panoya kopyalandı!");
        }

        function copyJsonTextModal() {
            copyJsonText();
        }

        // ── Unified Performance Battle Simulator Logic ─────
        let lastBattleData = null;

        function onScenarioChange() {
            const scenario = document.getElementById('battleScenarioSelect').value;
            const queryContainer = document.getElementById('battleQueryContainer');
            if (scenario === 'TextSearch') {
                queryContainer.style.display = 'block';
            } else {
                queryContainer.style.display = 'none';
            }

            // Reset labels, widths, and data buttons
            const lanes = ['sql', 'flat', 'es', 'cacheCold', 'cacheHot'];
            lanes.forEach(k => {
                const bar = document.getElementById('lane-bar-' + k);
                if (bar) bar.style.width = '0%';
                const lbl = document.getElementById('val-' + k);
                if (lbl) {
                    lbl.textContent = 'Henüz yarışmadı';
                    lbl.className = 'badge bg-dark border border-secondary text-secondary';
                }
                const btn = document.getElementById('btn-data-' + k);
                if (btn) btn.classList.add('d-none');
            });
        }

        async function runUnifiedBattle() {
            if (isBattleRunning) return;
            isBattleRunning = true;

            const btn = document.getElementById('startBattleBtn');
            const scenario = document.getElementById('battleScenarioSelect').value;
            const query = document.getElementById('battleQueryInput').value || 'hava';
            const announce = document.getElementById('battleAnnouncement');

            btn.disabled = true;
            btn.innerHTML = '<span class="bench-spinner"></span> Çarpışıyor...';
            announce.classList.add('d-none');

            // Reset all race bars and data buttons
            const bars = {
                sql: document.getElementById('lane-bar-sql'),
                flat: document.getElementById('lane-bar-flat'),
                es: document.getElementById('lane-bar-es'),
                cacheCold: document.getElementById('lane-bar-cacheCold'),
                cacheHot: document.getElementById('lane-bar-cacheHot')
            };

            const labels = {
                sql: document.getElementById('val-sql'),
                flat: document.getElementById('val-flat'),
                es: document.getElementById('val-es'),
                cacheCold: document.getElementById('val-cacheCold'),
                cacheHot: document.getElementById('val-cacheHot')
            };

            for (let k in bars) {
                if (bars[k]) {
                    bars[k].style.width = '0%';
                }
                if (labels[k]) {
                    labels[k].className = 'badge bg-dark border border-secondary text-secondary';
                    labels[k].textContent = 'Yarışıyor...';
                }
                const db = document.getElementById('btn-data-' + k);
                if (db) db.classList.add('d-none');
            }

            logToConsole(`Performans Savaşı Başlatıldı! Senaryo: ${scenario}`, "cmd");

            try {
                let url = '';
                let fetchOptions = { method: 'POST' };

                if (scenario === 'GetAllProducts') {
                    url = '/Benchmark/RunGetAllProducts';
                } else if (scenario === 'TextSearch') {
                    url = '/Benchmark/RunTextSearch';
                    fetchOptions.headers = { 'Content-Type': 'application/json' };
                    fetchOptions.body = JSON.stringify({ query: query });
                } else {
                    url = '/Benchmark/RunCacheTest';
                }

                const resp = await fetch(url, fetchOptions);
                const data = await resp.json();

                displayRawJson(data);

                // Define actual values
                const times = {
                    sql: data.sqlTimeMs,
                    flat: data.sqlReadModelTimeMs,
                    es: data.esTimeMs,
                    cacheCold: data.cacheColdMs,
                    cacheHot: data.cacheHotMs
                };

                const counts = {
                    sql: data.sqlCount,
                    flat: data.sqlReadModelCount || data.sqlCount,
                    es: data.esCount,
                    cacheCold: null,
                    cacheHot: data.cacheCount
                };

                // Run race simulation
                await simulateRace(times, counts, bars, labels, announce);

                // Show "Veriyi Gör" buttons for active lanes
                lastBattleData = data;
                for (let k in times) {
                    if (times[k] !== null && times[k] !== undefined && times[k] > 0) {
                        const db = document.getElementById('btn-data-' + k);
                        if (db) db.classList.remove('d-none');
                    }
                }

                // Add to history and charts AFTER the race finishes
                addToChart(data.scenario, data.sqlTimeMs, data.sqlReadModelTimeMs, data.esTimeMs, data.cacheColdMs, data.cacheHotMs);
                addToHistory(data);

                logToConsole(`Savaş tamamlandı! Senaryo: ${data.scenario}`, "success");

            } catch (err) {
                logToConsole(`Savaş sırasında hata oluştu: ${err.message}`, "warning");
                for (let k in labels) {
                    if (labels[k]) {
                        labels[k].textContent = 'Hata';
                        labels[k].className = 'badge bg-dark border border-danger text-danger';
                    }
                }
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-fire me-1"></i> SAVAŞI BAŞLAT!';
                isBattleRunning = false;
            }
        }

        function showLaneData(tech) {
            if (!lastBattleData) return;
            let targetData = null;
            let title = '';
            if (tech === 'sql') {
                targetData = lastBattleData.sqlData;
                title = 'SQL Server TPT Gelen Veri';
            } else if (tech === 'flat') {
                targetData = lastBattleData.sqlReadModelData;
                title = 'SQL Read Model Gelen Veri';
            } else if (tech === 'es') {
                targetData = lastBattleData.esData;
                title = 'Elasticsearch Gelen Veri';
            } else if (tech === 'cacheCold') {
                targetData = lastBattleData.cacheColdData;
                title = 'Cache Cold Gelen Veri';
            } else if (tech === 'cacheHot') {
                targetData = lastBattleData.cacheHotData;
                title = 'Cache Hot Gelen Veri';
            }

            document.getElementById('modalJsonRawPre').textContent = JSON.stringify(targetData, null, 4);
            document.getElementById('jsonFullscreenModalLabel').innerHTML = `<i class="bi bi-braces text-warning me-2"></i>${title}`;
            const myModal = new bootstrap.Modal(document.getElementById('jsonFullscreenModal'));
            myModal.show();
        }

        async function runAllUnifiedBattles() {
            if (isBattleRunning) return;

            const scenarios = ['GetAllProducts', 'TextSearch', 'CacheTest'];
            const selectEl = document.getElementById('battleScenarioSelect');
            const startAllBtn = document.getElementById('startAllBattleBtn');
            const originalText = startAllBtn.innerHTML;

            startAllBtn.disabled = true;
            startAllBtn.innerHTML = '<span class="bench-spinner"></span> Savaşlar Sürmekte...';

            logToConsole("Toplu Savaş Başlatıldı! Tüm servisler sırayla savaştırılıyor...", "cmd");

            // Reset chart for comparison
            benchChart.data.labels = [];
            benchChart.data.datasets.forEach(d => d.data = []);
            benchChart.update();

            for (let i = 0; i < scenarios.length; i++) {
                selectEl.value = scenarios[i];
                onScenarioChange();

                // Wait for the scenario's battle to complete
                await runUnifiedBattle();

                if (i < scenarios.length - 1) {
                    await new Promise(r => setTimeout(r, 1000));
                }
            }

            startAllBtn.disabled = false;
            startAllBtn.innerHTML = originalText;
        }

        async function simulateRace(times, counts, bars, labels, announce) {
            return new Promise((resolve) => {
                // Find min active time
                let minTime = Infinity;
                let activeKeys = [];
                let inactiveKeys = [];

                for (let k in times) {
                    if (times[k] !== null && times[k] !== undefined && times[k] > 0) {
                        activeKeys.push(k);
                        if (times[k] < minTime) {
                            minTime = times[k];
                        }
                    } else {
                        inactiveKeys.push(k);
                    }
                }

                // Immediately mark inactive keys
                inactiveKeys.forEach(k => {
                    if (labels[k]) {
                        labels[k].textContent = 'Kullanılmıyor';
                        labels[k].className = 'badge bg-dark border border-secondary text-secondary opacity-50';
                    }
                    if (bars[k]) {
                        bars[k].style.width = '0%';
                    }
                });

                // Progress state for active lanes
                const progress = {};
                activeKeys.forEach(k => {
                    progress[k] = 0;
                    if (labels[k]) {
                        labels[k].textContent = 'Koşuyor...';
                    }
                });

                // Calculate step increments based on relative speeds, capped so slowest finishes in max ~3 seconds (min increment of 0.8% per tick)
                const step = 4.0; 
                const increments = {};
                activeKeys.forEach(k => {
                    const ratio = minTime / times[k];
                    increments[k] = Math.max(0.8, step * ratio);
                });

                const raceInterval = setInterval(() => {
                    let allFinished = true;

                    activeKeys.forEach(k => {
                        if (progress[k] < 100) {
                            progress[k] += increments[k] + (Math.random() - 0.2) * 0.2; 
                            if (progress[k] >= 100) {
                                progress[k] = 100;
                                // Display final result
                                const timeStr = times[k].toFixed(2) + ' ms';
                                const countStr = counts[k] !== null && counts[k] !== undefined ? ` (${counts[k]} kayıt)` : '';
                                labels[k].textContent = timeStr + countStr;
                                
                                // Set color based on speed relative to winner
                                if (times[k] === minTime) {
                                    labels[k].className = 'badge bg-success border border-success text-white fw-bold animate__animated animate__pulse';
                                } else {
                                    labels[k].className = 'badge bg-dark border border-secondary text-light';
                                }
                            } else {
                                allFinished = false;
                            }
                            if (bars[k]) {
                                bars[k].style.width = progress[k] + '%';
                            }
                        }
                    });

                    if (allFinished) {
                        clearInterval(raceInterval);

                        // Show announcement
                        let winnerKey = '';
                        let minVal = Infinity;
                        for (let k in times) {
                            if (times[k] !== null && times[k] !== undefined && times[k] > 0 && times[k] < minVal) {
                                minVal = times[k];
                                winnerKey = k;
                            }
                        }

                        const techNames = {
                            sql: 'SQL Server TPT',
                            flat: 'SQL Read Model',
                            es: 'Elasticsearch',
                            cacheCold: 'Memory Cache Cold',
                            cacheHot: 'Memory Cache Hot'
                        };

                        announce.className = 'battle-announcement text-center animate__animated animate__fadeIn mt-3';
                        announce.classList.remove('d-none');
                        
                        let comparisonText = '';
                        let maxVal = 0;
                        let loserKey = '';
                        for (let k in times) {
                            if (times[k] !== null && times[k] !== undefined && times[k] > 0 && times[k] > maxVal) {
                                maxVal = times[k];
                                loserKey = k;
                            }
                        }

                        if (winnerKey && loserKey && winnerKey !== loserKey) {
                            const ratio = (times[loserKey] / times[winnerKey]).toFixed(1);
                            comparisonText = `<strong>${techNames[winnerKey]}</strong>, en yavaş olan <strong>${techNames[loserKey]}</strong> karşısında <strong>${ratio}x kat daha hızlı</strong> performans gösterdi.`;
                        }

                        announce.innerHTML = `
                            <div style="font-size: 1.1rem; font-weight: 700; color: #4ade80;">
                                🎉 Savaş Tamamlandı! Kazanan: ${techNames[winnerKey]} (${times[winnerKey].toFixed(2)} ms)
                            </div>
                            <div class="mt-2" style="font-size: 0.88rem; color: #cbd5e1;">
                                ${comparisonText}
                            </div>
                        `;

                        resolve();
                    }
                }, 25);
            });
        }

        // Initialize Styles and fetch counts
        onScenarioChange();
        fetchCounts();
    </script>
}
