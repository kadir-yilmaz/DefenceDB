        <!-- ═══════════════ ARCHITECTURE DIAGRAM (SVG) ═══════════════ -->
        <div class="arch-diagram fade-in-section">
            <div class="d-flex align-items-center mb-3">
                <span class="chart-title mb-0"><i class="bi bi-diagram-3-fill me-2" style="color: #38bdf8;"></i>Sistem Mimarisi & Canlı İstek Yolu</span>
            </div>
            <div style="width: 100%; overflow-x: auto;">
                <svg viewBox="0 0 800 240" class="w-100" style="min-width: 700px; max-height: 280px;">
                    <defs>
                        <!-- Gradients for nodes -->
                        <linearGradient id="grad-client" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#475569" />
                            <stop offset="100%" stop-color="#1e293b" />
                        </linearGradient>
                        <linearGradient id="grad-controller" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#0ea5e9" />
                            <stop offset="100%" stop-color="#0369a1" />
                        </linearGradient>
                        <linearGradient id="grad-sql" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#3b82f6" />
                            <stop offset="100%" stop-color="#1d4ed8" />
                        </linearGradient>
                        <linearGradient id="grad-flat" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#10b981" />
                            <stop offset="100%" stop-color="#047857" />
                        </linearGradient>
                        <linearGradient id="grad-cache" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#f59e0b" />
                            <stop offset="100%" stop-color="#b45309" />
                        </linearGradient>
                        <linearGradient id="grad-es" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#a855f7" />
                            <stop offset="100%" stop-color="#6d28d9" />
                        </linearGradient>
                    </defs>

                    <!-- Connections -->
                    <path id="flow-client-controller" d="M 130 120 L 210 120" stroke="#334155" stroke-width="3" fill="none" />
                    <path id="flow-controller-sql" d="M 330 100 C 370 60, 390 40, 450 40" stroke="#334155" stroke-width="3" fill="none" />
                    <path id="flow-controller-flat" d="M 330 120 L 450 120" stroke="#334155" stroke-width="3" fill="none" />
                    <path id="flow-controller-cache" d="M 330 140 C 370 180, 390 200, 450 200" stroke="#334155" stroke-width="3" fill="none" />
                    <path id="flow-sql-sync" d="M 510 70 L 510 90" stroke="#475569" stroke-width="2" stroke-dasharray="4,4" fill="none" />
                    @if(useEs) {
                        <path id="flow-controller-es" d="M 330 120 C 400 120, 500 120, 670 120" stroke="#334155" stroke-width="3" fill="none" />
                    }

                    <!-- Flowing Dots -->
                    <circle id="dot-client-controller" r="5" fill="#38bdf8" opacity="0"><animateMotion dur="1.2s" repeatCount="indefinite" path="M 130 120 L 210 120" /></circle>
                    <circle id="dot-controller-sql" r="5" fill="#60a5fa" opacity="0"><animateMotion dur="1.2s" repeatCount="indefinite" path="M 330 100 C 370 60, 390 40, 450 40" /></circle>
                    <circle id="dot-controller-flat" r="5" fill="#34d399" opacity="0"><animateMotion dur="1.2s" repeatCount="indefinite" path="M 330 120 L 450 120" /></circle>
                    <circle id="dot-controller-cache" r="5" fill="#fbbf24" opacity="0"><animateMotion dur="1.2s" repeatCount="indefinite" path="M 330 140 C 370 180, 390 200, 450 200" /></circle>
                    @if(useEs) {
                        <circle id="dot-controller-es" r="5" fill="#a78bfa" opacity="0"><animateMotion dur="1.2s" repeatCount="indefinite" path="M 330 120 C 400 120, 500 120, 670 120" /></circle>
                    }

                    <!-- Nodes -->
                    <!-- 1. Client -->
                    <g id="node-client" transform="translate(30, 90)">
                        <rect width="100" height="60" rx="8" fill="url(#grad-client)" stroke="#475569" stroke-width="1.5" />
                        <text x="50" y="28" fill="#e2e8f0" font-family="Outfit" font-size="12" font-weight="bold" text-anchor="middle">🖥️ Client</text>
                        <text x="50" y="44" fill="#94a3b8" font-family="Inter" font-size="10" text-anchor="middle">Browser</text>
                    </g>

                    <!-- 2. Controller -->
                    <g id="node-controller" transform="translate(210, 90)">
                        <rect width="120" height="60" rx="8" fill="url(#grad-controller)" stroke="#0284c7" stroke-width="1.5" />
                        <text x="60" y="28" fill="#e2e8f0" font-family="Outfit" font-size="12" font-weight="bold" text-anchor="middle">⚙️ ASP.NET Core</text>
                        <text x="60" y="44" fill="#bae6fd" font-family="Inter" font-size="10" text-anchor="middle">Controller / BLL</text>
                    </g>

                    <!-- 3. SQL Server TPT -->
                    <g id="node-sql" transform="translate(450, 10)">
                        <rect width="120" height="60" rx="8" fill="url(#grad-sql)" stroke="#2563eb" stroke-width="1.5" />
                        <text x="60" y="28" fill="#e2e8f0" font-family="Outfit" font-size="12" font-weight="bold" text-anchor="middle">🗄️ SQL TPT</text>
                        <text x="60" y="44" fill="#93c5fd" font-family="Inter" font-size="9" text-anchor="middle">20+ JOINs Table</text>
                    </g>

                    <!-- 4. SQL Read Model -->
                    <g id="node-flat" transform="translate(450, 90)">
                        <rect width="120" height="60" rx="8" fill="url(#grad-flat)" stroke="#059669" stroke-width="1.5" />
                        <text x="60" y="28" fill="#e2e8f0" font-family="Outfit" font-size="12" font-weight="bold" text-anchor="middle">📋 Read Model</text>
                        <text x="60" y="44" fill="#a7f3d0" font-family="Inter" font-size="9" text-anchor="middle">CQRS Düz Tablo</text>
                    </g>

                    <!-- 5. In-Memory Cache -->
                    <g id="node-cache" transform="translate(450, 170)">
                        <rect width="120" height="60" rx="8" fill="url(#grad-cache)" stroke="#d97706" stroke-width="1.5" />
                        <text x="60" y="28" fill="#e2e8f0" font-family="Outfit" font-size="12" font-weight="bold" text-anchor="middle">⚡ Memory Cache</text>
                        <text x="60" y="44" fill="#fde047" font-family="Inter" font-size="9" text-anchor="middle">Ultra Hızlı RAM</text>
                    </g>

                    <!-- 6. Elasticsearch -->
                    @if(useEs) {
                        <g id="node-es" transform="translate(650, 90)">
                            <rect width="120" height="60" rx="8" fill="url(#grad-es)" stroke="#7c3aed" stroke-width="1.5" />
                            <text x="60" y="28" fill="#e2e8f0" font-family="Outfit" font-size="12" font-weight="bold" text-anchor="middle">🔍 Elasticsearch</text>
                            <text x="60" y="44" fill="#ddd6fe" font-family="Inter" font-size="9" text-anchor="middle">Full-Text Search</text>
                        </g>
                    }
                </svg>
            </div>
        </div>

        <!-- ═══════════════ TEST HISTORY TABLE ═══════════════ -->
