@{
    ViewData["Title"] = "Performans Benchmark";
    var useEs = ViewData["UseElasticsearch"] as bool? ?? false;
}

<style>
    /* ═══════════════════════════════════════════════════════════
       BENCHMARK DASHBOARD — GLASSMORPHIC DARK THEME v2
       ═══════════════════════════════════════════════════════════ */

    /* Override the global * transition from site.css that causes flicker */
    .benchmark-hero,
    .benchmark-hero *,
    .benchmark-hero *::before,
    .benchmark-hero *::after {
        transition: none !important;
    }
    /* Re-enable only specific transitions we actually want */
    .benchmark-hero .glass-card {
        transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease !important;
    }
    .benchmark-hero .bench-btn {
        transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease !important;
    }
    .benchmark-hero .bench-search-input {
        transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
    }
    .benchmark-hero .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease !important;
    }
    .benchmark-hero .history-row {
        transition: background 0.2s ease !important;
    }

    /* Force dark background on entire page to prevent white flash */
    body:has(.benchmark-hero),
    body:has(.benchmark-hero) .app-container,
    body:has(.benchmark-hero) main {
        background-color: #0f172a !important;
    }

    .benchmark-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
        min-height: 100vh;
        padding: 2rem 0 4rem;
        position: relative;
        overflow: hidden;
    }

    .benchmark-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 50%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                    radial-gradient(ellipse at 70% 20%, rgba(168, 85, 247, 0.06) 0%, transparent 50%),
                    radial-gradient(ellipse at 50% 80%, rgba(245, 158, 11, 0.04) 0%, transparent 50%);
        pointer-events: none;
        will-change: opacity;
        animation: auroraFade 8s ease-in-out infinite alternate;
    }

    @@keyframes auroraFade {
        0% { opacity: 0.6; }
        100% { opacity: 1; }
    }

    .bench-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 800;
        font-size: 2.5rem;
        background: linear-gradient(135deg, #60a5fa, #a78bfa, #f59e0b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
    }

    .bench-subtitle {
        color: #94a3b8;
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        letter-spacing: 0.5px;
    }

    /* Status badges */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 9999px;
        font-size: 0.8rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        backdrop-filter: blur(10px);
    }

    .status-active {
        background: rgba(34, 197, 94, 0.15);
        color: #4ade80;
        border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .status-inactive {
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
    }

    .status-active .status-dot {
        background: #4ade80;
        box-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
        animation: pulse-green 2s infinite;
    }

    .status-inactive .status-dot {
        background: #f87171;
    }

    @@keyframes pulse-green {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    /* Glass card */
    .glass-card {
        background: rgba(30, 41, 59, 0.5);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(148, 163, 184, 0.1);
        border-radius: 16px;
        padding: 1.75rem;
        position: relative;
        overflow: hidden;
    }

    .glass-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.2), transparent);
    }

    .glass-card:hover {
        border-color: rgba(148, 163, 184, 0.2);
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .card-title-sm {
        font-family: 'Outfit', sans-serif;
        font-weight: 600;
        color: #e2e8f0;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }

    .card-desc {
        color: #94a3b8;
        font-size: 0.85rem;
        font-family: 'Inter', sans-serif;
        margin-bottom: 1rem;
    }

    /* Scenario buttons */
    .bench-btn {
        font-family: 'Inter', sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 10px 24px;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        position: relative;
        overflow: hidden;
    }

    .bench-btn::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
        opacity: 0;
        transition: opacity 0.25s ease;
    }

    .bench-btn:hover::after {
        opacity: 1;
    }

    .bench-btn-primary {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #fff;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

    .bench-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
    }

    .bench-btn-purple {
        background: linear-gradient(135deg, #a855f7, #7c3aed);
        color: #fff;
        box-shadow: 0 4px 15px rgba(168, 85, 247, 0.3);
    }

    .bench-btn-amber {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #1e293b;
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
    }

    .bench-btn-success {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: #fff;
        box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);
    }

    .bench-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none !important;
    }

    /* Results area */
    .result-panel {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(148, 163, 184, 0.08);
        border-radius: 12px;
        padding: 1.25rem;
        margin-top: 1rem;
        min-height: 80px;
    }

    .result-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid rgba(148, 163, 184, 0.06);
    }

    .result-row:last-child {
        border-bottom: none;
    }

    .result-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .result-value {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-weight: 700;
        font-size: 1rem;
    }

    .result-value.fast {
        color: #4ade80;
        text-shadow: 0 0 10px rgba(74, 222, 128, 0.3);
    }

    .result-value.medium {
        color: #fbbf24;
    }

    .result-value.slow {
        color: #f87171;
    }

    .result-count {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: #64748b;
        margin-left: 8px;
    }

    /* Chart container */
    .chart-container {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid rgba(148, 163, 184, 0.08);
        border-radius: 16px;
        padding: 1.5rem;
        margin-top: 2rem;
    }

    .chart-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 600;
        color: #e2e8f0;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }

    /* Loading spinner */
    .bench-spinner {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    /* Search input */
    .bench-search-input {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(148, 163, 184, 0.15);
        border-radius: 10px;
        color: #e2e8f0;
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        padding: 10px 16px;
        width: 100%;
        transition: border-color 0.2s ease;
    }

    .bench-search-input:focus {
        outline: none;
        border-color: rgba(59, 130, 246, 0.5);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .bench-search-input::placeholder {
        color: #64748b;
    }

    /* Architecture badges */
    .arch-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        font-family: 'JetBrains Mono', monospace;
    }

    .arch-badge.sql { background: rgba(59, 130, 246, 0.15); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.25); }
    .arch-badge.sql-flat { background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.25); }
    .arch-badge.es { background: rgba(168, 85, 247, 0.15); color: #a78bfa; border: 1px solid rgba(168, 85, 247, 0.25); }
    .arch-badge.cache { background: rgba(245, 158, 11, 0.15); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.25); }

    /* ═══════════════ STAT CARDS ═══════════════ */
    .stat-card {
        background: rgba(30, 41, 59, 0.4);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(148, 163, 184, 0.08);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: var(--stat-accent, linear-gradient(90deg, #3b82f6, #60a5fa));
    }
    .stat-card:hover {
        border-color: rgba(148, 163, 184, 0.15);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    }
    .stat-icon {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        display: block;
    }
    .stat-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.75rem;
        font-weight: 800;
        color: #f1f5f9;
        line-height: 1;
        margin-bottom: 0.25rem;
    }
    .stat-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.78rem;
        color: #94a3b8;
        font-weight: 500;
    }

    /* ═══════════════ ARCHITECTURE DIAGRAM (SVG) ═══════════════ */
    .arch-diagram {
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid rgba(148, 163, 184, 0.08);
        border-radius: 16px;
        padding: 2rem;
        margin-top: 2rem;
        position: relative;
        overflow: hidden;
    }
    .arch-diagram svg {
        display: block;
        width: 100%;
        height: auto;
    }
    svg g rect {
        transition: stroke-width 0.3s ease, stroke 0.3s ease, filter 0.3s ease;
    }
    svg path {
        transition: stroke 0.3s ease, stroke-width 0.3s ease;
    }

    /* ═══════════════ BATTLE SIMULATOR ═══════════════ */
    .battle-container {
        margin-top: 2rem;
    }
    .vs-badge {
        font-family: 'Outfit', sans-serif;
        font-weight: 900;
        font-size: 2.2rem;
        background: linear-gradient(135deg, #ef4444, #f59e0b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 10px rgba(239, 68, 68, 0.4));
        margin-bottom: 0.5rem;
    }
    .battle-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.78rem;
        color: #94a3b8;
        font-weight: 600;
        margin-bottom: 6px;
        display: block;
    }
    .racetrack {
        background: #020617;
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 8px;
        height: 38px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding: 0 10px;
    }
    .racetrack::after {
        content: '🏁';
        position: absolute;
        right: 10px;
        font-size: 1.1rem;
        z-index: 2;
    }
    .race-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, transparent, var(--race-color, #3b82f6));
        position: absolute;
        left: 0;
        top: 0;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: 30px;
        transition: width 0.05s linear;
    }
    .race-car {
        font-size: 1.2rem;
        color: #fff;
        filter: drop-shadow(0 0 8px var(--race-color, #3b82f6));
        transform: scaleX(1);
        position: absolute;
        right: 5px;
    }
    .battle-stats {
        background: rgba(15, 23, 42, 0.3);
        border: 1px solid rgba(148, 163, 184, 0.06);
        border-radius: 8px;
        padding: 10px 14px;
        font-family: 'Inter', sans-serif;
    }
    .battle-stat-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #94a3b8;
        margin-bottom: 4px;
    }
    .battle-stat-row:last-child { margin-bottom: 0; }
    .battle-stat-row strong {
        font-family: 'JetBrains Mono', monospace;
        color: #f1f5f9;
    }
    .battle-announcement {
        border-radius: 10px;
        padding: 1rem;
        font-family: 'Outfit', sans-serif;
        font-size: 1rem;
        color: #f1f5f9;
        margin-top: 1rem;
        border: 1px dashed rgba(148, 163, 184, 0.15);
        background: rgba(30, 41, 59, 0.3);
    }

    /* ═══════════════ LIVE DEVELOPER CONSOLE ═══════════════ */
    .console-container {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid rgba(148, 163, 184, 0.08);
        border-radius: 16px;
        padding: 1.5rem;
        margin-top: 2rem;
    }
    .console-box {
        background: #020617;
        border: 1px solid rgba(148, 163, 184, 0.12);
        border-radius: 10px;
        padding: 1rem;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.8rem;
        height: 180px;
        overflow-y: auto;
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.8);
    }
    .console-line {
        margin-bottom: 4px;
        line-height: 1.4;
        white-space: pre-wrap;
    }
    .console-line.info { color: #38bdf8; }
    .console-line.cmd { color: #a78bfa; font-weight: 600; }
    .console-line.sql { color: #60a5fa; }
    .console-line.cqrs { color: #34d399; }
    .console-line.es { color: #c084fc; }
    .console-line.cache { color: #fbbf24; }
    .console-line.success { color: #4ade80; }
    .console-line.warning { color: #f87171; }

    /* ═══════════════ EXPANDABLE HISTORY DETAILS ═══════════════ */
    .bg-dark-card {
        background: rgba(15, 23, 42, 0.8) !important;
    }
    .detail-container {
        border: 1px solid rgba(148, 163, 184, 0.1);
        border-radius: 10px;
        padding: 1.25rem;
        background: #0f172a;
    }
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 1.5rem;
    }
    @@media (max-width: 768px) {
        .detail-grid {
            grid-template-columns: 1fr;
        }
    }
    .detail-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        color: #e2e8f0;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .performance-bar-wrap {
        margin-bottom: 12px;
    }
    .performance-bar-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: #94a3b8;
        margin-bottom: 4px;
    }
    .performance-bar-outer {
        background: #1e293b;
        height: 12px;
        border-radius: 9999px;
        overflow: hidden;
        position: relative;
    }
    .performance-bar-inner {
        height: 100%;
        border-radius: 9999px;
        background: var(--bar-color, #3b82f6);
        transition: width 0.5s ease-out;
    }
    .query-code-block {
        background: #020617;
        border: 1px solid rgba(148, 163, 184, 0.1);
        border-radius: 6px;
        padding: 10px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: #cbd5e1;
        max-height: 110px;
        overflow-y: auto;
        white-space: pre-wrap;
    }
    .perf-tier {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        font-family: 'JetBrains Mono', monospace;
    }
    .perf-tier.tier-s { background: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); } /* S Tier: < 2ms */
    .perf-tier.tier-a { background: rgba(56, 189, 248, 0.15); color: #38bdf8; border: 1px solid rgba(56, 189, 248, 0.3); } /* A Tier: 2-20ms */
    .perf-tier.tier-b { background: rgba(245, 158, 11, 0.15); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.3); } /* B Tier: 20-100ms */
    .perf-tier.tier-c { background: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.3); } /* C Tier: > 100ms */
    
    .recommendation-text {
        font-size: 0.8rem;
        color: #94a3b8;
        line-height: 1.4;
        background: rgba(30, 41, 59, 0.3);
        border-left: 3px solid #3b82f6;
        padding: 8px 12px;
        border-radius: 0 6px 6px 0;
    }

    /* ═══════════════ GENERAL ESTHETIC & SCENARIOS ═══════════════ */
    .winner-badge {
        font-size: 0.7rem;
    }
    .history-row {
        cursor: pointer;
    }
    .history-row:hover td {
        color: #fff !important;
    }

    /* Section fade-in */
    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .fade-in-section {
        animation: fadeSlideUp 0.5s ease-out forwards;
    }

    /* Test history table and stats white text colors */
    .history-table th,
    .history-empty,
    .history-stats-bar,
    .history-stats-bar span,
    .history-stats-bar .hs-val {
        color: #ffffff !important;
    }
</style>

<script>
    // Immediately force dark background to prevent white flash
    document.body.style.backgroundColor = '#0f172a';
    var appContainer = document.querySelector('.app-container');
    if (appContainer) appContainer.style.backgroundColor = '#0f172a';
    var mainEl = document.querySelector('main');
    if (mainEl) mainEl.style.backgroundColor = '#0f172a';
</script>

<div class="benchmark-hero">
    <div class="container position-relative" style="z-index: 1;">

        <!-- Header -->
        <div class="row align-items-center mb-4 pt-4">
            <div class="col-lg-7 text-center text-lg-start">
                <h1 class="bench-title">
                    <i class="bi bi-speedometer2 me-2"></i>Performans Benchmark
                </h1>
                <p class="bench-subtitle mb-2">
                    TPT (SQL Server) vs Elasticsearch vs In-Memory Cache — Gerçek zamanlı karşılaştırma
                </p>
                <div class="d-flex justify-content-center justify-content-lg-start gap-2 flex-wrap mt-2">
                    <span class="status-badge @(useEs ? "status-active" : "status-inactive")">
                        <span class="status-dot"></span>
                        Elasticsearch
                    </span>
                    <span class="status-badge status-active">
                        <span class="status-dot"></span>
                        SQL Server (TPT)
                    </span>
                    <span class="status-badge status-active">
                        <span class="status-dot" style="background:#34d399;"></span>
                        SQL Read Model (Flat)
                    </span>
                    <span class="status-badge status-active">
                        <span class="status-dot" style="background:#fbbf24;"></span>
                        In-Memory Cache
                    </span>
                </div>
            </div>
            <div class="col-lg-5 text-center text-lg-end mt-3 mt-lg-0">
                <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-end gap-2">
                    @if(useEs) {
                        <div class="d-inline-block text-start">
                            <button id="btnEsReindex" class="bench-btn bench-btn-success w-100" onclick="reindex(this)">
                                <i class="bi bi-arrow-repeat me-1"></i> ES Reindex
                            </button>
                            <div id="statusEs" class="text-muted small mt-1 text-center text-lg-end" style="font-size: 0.72rem; font-family: 'JetBrains Mono', monospace;">
                                ES Durum: Yükleniyor...
                            </div>
                        </div>
                    }
                    <div class="d-inline-block text-start">
                        <button id="btnSyncReadModels" class="bench-btn w-100" style="background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3);" onclick="syncReadModels(this)">
                            <i class="bi bi-database-fill-down me-1"></i> Read Table Reindex
                        </button>
                        <div id="statusReadModel" class="text-muted small mt-1 text-center text-lg-end" style="font-size: 0.72rem; font-family: 'JetBrains Mono', monospace;">
                            Read Table: Yükleniyor...
                        </div>
                    </div>
                </div>
            </div>
        </div>

