@{
    var currentCategory = ViewBag.CurrentCategory as Category;
    var filterProps = ViewBag.FilterProperties as List<System.Reflection.PropertyInfo>;
}

@if (filterProps != null && filterProps.Any())
{
    <form method="get" action="@Url.Action("Index", "Product")">
        <input type="hidden" name="categorySlug" value="@(currentCategory?.Slug)" />
        <input type="hidden" name="country" value="@ViewBag.CurrentCountry" />
        <input type="hidden" name="search" value="@ViewBag.CurrentSearch" />
        
        @foreach (var prop in filterProps)
        {
            var currentVal = Context.Request.Query[prop.Name].ToString();
            
            <div class="mb-3">
                <label class="form-label text-secondary-theme small">@prop.Name</label>
                
                @if (prop.Name == "Generation")
                {
                    <select name="@prop.Name" class="form-select form-select-sm bg-theme text-primary-theme border-theme" onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()">
                        <option value="">Tümü</option>
                        <option value="1" selected="@(currentVal == "1" ? "selected" : null)">1. Nesil</option>
                        <option value="2" selected="@(currentVal == "2" ? "selected" : null)">2. Nesil</option>
                        <option value="3" selected="@(currentVal == "3" ? "selected" : null)">3. Nesil</option>
                        <option value="4" selected="@(currentVal == "4" ? "selected" : null)">4. Nesil</option>
                        <option value="4.5" selected="@(currentVal == "4.5" ? "selected" : null)">4.5 Nesil</option>
                        <option value="5" selected="@(currentVal == "5" ? "selected" : null)">5. Nesil</option>
                        <option value="6" selected="@(currentVal == "6" ? "selected" : null)">6. Nesil</option>
                    </select>
                }
                else if (prop.PropertyType == typeof(bool))
                {
                    <select name="@prop.Name" class="form-select form-select-sm bg-theme text-primary-theme border-theme" onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()">
                        <option value="">Tümü</option>
                        <option value="true" selected="@(currentVal == "true" ? "selected" : null)">Evet</option>
                        <option value="false" selected="@(currentVal == "false" ? "selected" : null)">Hayır</option>
                    </select>
                }
                else if (prop.PropertyType == typeof(int) || prop.PropertyType == typeof(int?))
                {
                    <input type="number" name="@prop.Name" class="form-control form-control-sm bg-theme text-primary-theme border-theme" placeholder="Sayı girin..." value="@currentVal" onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()" />
                }
                else if (prop.PropertyType == typeof(double) || prop.PropertyType == typeof(double?))
                {
                    <input type="number" step="0.01" name="@prop.Name" class="form-control form-control-sm bg-theme text-primary-theme border-theme" placeholder="Sayı girin..." value="@currentVal" onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()" />
                }
                else if (prop.Name == "GuidanceType")
                {
                    string[] availableTypes = new[] { "IR", "IIR", "RF", "SARH", "Pasif", "EO" };
                    var currentVals = Context.Request.Query[prop.Name].ToArray();
                    
                    <div class="d-flex flex-column gap-2 mt-2">
                        @foreach(var type in availableTypes)
                        {
                            bool isChecked = currentVals.Contains(type);
                            <div class="form-check custom-checkbox">
                                <input class="form-check-input border-theme" type="checkbox" name="@prop.Name" value="@type" id="filter_guidance_@type" @(isChecked ? "checked" : "") onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()">
                                <label class="form-check-label text-primary-theme small" for="filter_guidance_@type">@type</label>
                            </div>
                        }
                    </div>
                }
                else if (prop.Name == "FoxCode")
                {
                    string[] availableFoxes = new[] { "1", "2", "3" };
                    var currentVals = Context.Request.Query[prop.Name].ToArray();
                    
                    <div class="d-flex flex-column gap-2 mt-2">
                        @foreach(var fox in availableFoxes)
                        {
                            bool isChecked = currentVals.Contains(fox);
                            <div class="form-check custom-checkbox">
                                <input class="form-check-input border-theme" type="checkbox" name="@prop.Name" value="@fox" id="filter_fox_@fox" @(isChecked ? "checked" : "") onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()">
                                <label class="form-check-label text-primary-theme fw-bold small text-danger" for="filter_fox_@fox">Fox @fox</label>
                            </div>
                        }
                    </div>
                }
                else if (prop.Name == "BallisticType")
                {
                    string[] ballisticTypes = new[] { "SRBM", "MRBM", "IRBM", "ICBM", "SLBM", "ALBM" };
                    <select name="@prop.Name" class="form-select form-select-sm bg-theme text-primary-theme border-theme" onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()">
                        <option value="">Tümü</option>
                        @foreach(var bt in ballisticTypes)
                        {
                            if (currentVal == bt)
                            {
                                <option value="@bt" selected>@bt</option>
                            }
                            else
                            {
                                <option value="@bt">@bt</option>
                            }
                        }
                    </select>
                }
                else
                {
                    <input type="text" name="@prop.Name" class="form-control form-control-sm bg-theme text-primary-theme border-theme" placeholder="Aranacak değer..." value="@currentVal" onchange="sessionStorage.setItem('filterScroll', window.scrollY); this.form.submit()" />
                }
            </div>
        }
        
        @{
            var clearUrl = Url.Action("Index", "Product", new { categorySlug = currentCategory?.Slug, country = ViewBag.CurrentCountry, search = ViewBag.CurrentSearch });
        }
        <a href="@clearUrl" class="btn btn-outline-secondary btn-sm w-100 mt-2" onclick="sessionStorage.setItem('filterScroll', window.scrollY);">Temizle</a>
    </form>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var scroll = sessionStorage.getItem('filterScroll');
            if (scroll !== null) {
                window.scrollTo({ top: parseInt(scroll), behavior: 'instant' });
                sessionStorage.removeItem('filterScroll');
            }
        });
    </script>
}
