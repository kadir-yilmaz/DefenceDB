@model DefenceDB.EL.Models.DefenseProduct
@{
    var mainImage = Model.Images?.FirstOrDefault(i => i.IsMainImage)?.ImagePath ?? Model.Images?.FirstOrDefault()?.ImagePath ?? "/images/default.jpg";
    var galleryImages = Model.Images?.Where(i => i.ImagePath != mainImage).ToList() ?? new List<DefenceDB.EL.Models.ProductImage>();
    var galleryImagePaths = new[] { mainImage }.Concat(galleryImages.Select(i => i.ImagePath)).ToList();
}

<script>
    // Tüm görselleri tutacak dinamik galeri dizisi
    var galleryImages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(galleryImagePaths));

    var currentImageIndex = 0;
    var preloadedImages = new Map();
    var galleryLayers = new Map();

    function setGalleryLoading(isLoading) {
        var container = document.querySelector('.gallery-container');
        var mainImg = document.getElementById('mainGalleryImage');

        if (container) container.classList.toggle('is-loading', isLoading);
        if (mainImg) mainImg.classList.toggle('is-loading', isLoading);
    }

    function getGalleryLayer(index) {
        if (index === 0) {
            var mainImg = document.getElementById('mainGalleryImage');
            if (mainImg && !galleryLayers.has(0)) galleryLayers.set(0, mainImg);
            return mainImg;
        }

        return galleryLayers.get(index);
    }

    function createGalleryLayer(index, loadedImage) {
        if (!loadedImage || galleryLayers.has(index)) return getGalleryLayer(index);

        var container = document.querySelector('.gallery-container');
        if (!container) return null;

        var layer = document.createElement('img');
        layer.src = loadedImage.src;
        layer.alt = '@Model.Name.Replace("'", "\\'")';
        layer.decoding = 'async';
        layer.className = 'gallery-main';
        layer.dataset.galleryIndex = index;
        layer.onclick = openLightbox;
        layer.onerror = function() { handleImageError(layer, '@Model.Name.Replace("'", "\\'")'); };

        container.insertBefore(layer, container.firstChild);
        galleryLayers.set(index, layer);

        return layer;
    }

    function activateGalleryLayer(index) {
        galleryLayers.forEach(function(layer, layerIndex) {
            layer.classList.toggle('is-active', layerIndex === index);
        });
    }

    function preloadGalleryImage(index) {
        if (galleryImages.length === 0) return Promise.resolve();

        if (index < 0) index = galleryImages.length - 1;
        if (index >= galleryImages.length) index = 0;

        var src = galleryImages[index];
        if (!src) return Promise.resolve();
        if (preloadedImages.has(src)) return preloadedImages.get(src).promise;

        var img = new Image();
        img.decoding = 'async';
        img.loading = 'eager';

        var promise = new Promise(function(resolve) {
            img.onload = function() {
                if (img.decode) {
                    img.decode().then(function() { resolve(img); }).catch(function() { resolve(img); });
                } else {
                    resolve(img);
                }
            };
            img.onerror = function() { resolve(null); };
        });

        preloadedImages.set(src, { image: img, promise: promise });
        img.src = src;

        return promise;
    }

    function preloadAdjacentImages() {
        [currentImageIndex + 1, currentImageIndex - 1].forEach(function(index) {
            if (index < 0) index = galleryImages.length - 1;
            if (index >= galleryImages.length) index = 0;

            preloadGalleryImage(index).then(function(loadedImage) {
                createGalleryLayer(index, loadedImage);
            });
        });
    }

    function preloadGalleryInBackground() {
        var work = function() {
            galleryImages.forEach(function(_, index) {
                if (index !== currentImageIndex) {
                    preloadGalleryImage(index).then(function(loadedImage) {
                        createGalleryLayer(index, loadedImage);
                    });
                }
            });
        };

        if ('requestIdleCallback' in window) {
            window.requestIdleCallback(work, { timeout: 1600 });
        } else {
            window.setTimeout(work, 450);
        }
    }

    function updateGalleryImage(index) {
        if (galleryImages.length === 0) return;
        
        if (index < 0) index = galleryImages.length - 1;
        if (index >= galleryImages.length) index = 0;
        currentImageIndex = index;

        var newSrc = galleryImages[currentImageIndex];
        
        // Ana resmi doğrudan güncelle
        var mainImg = document.getElementById('mainGalleryImage');
        if (mainImg) {
            setGalleryLoading(true);
            
            // Önce resmi preload et, sonra göster
            preloadGalleryImage(currentImageIndex).then(function(loadedImage) {
                if (loadedImage) {
                    mainImg.src = newSrc;
                }
            }).finally(function() {
                setGalleryLoading(false);
            });
        }
        
        // Thumbnail aktiflik sınıflarını güncelle
        var thumbs = document.querySelectorAll('.gallery-thumb');
        thumbs.forEach(function(t) {
            t.classList.remove('active');
        });
        if (thumbs[currentImageIndex]) {
            thumbs[currentImageIndex].classList.add('active');
        }

        // Eğer lightbox açıksa onun da resmini ve sayacını güncelle
        var modal = document.getElementById('lightboxModal');
        var lightboxImg = document.getElementById('lightboxImage');
        if (modal && modal.classList.contains('show') && lightboxImg) {
            lightboxImg.src = newSrc;
        }
        
        var counter = document.getElementById('lightboxCounter');
        if (counter) counter.innerText = (currentImageIndex + 1) + ' / ' + galleryImages.length;

        preloadAdjacentImages();
    }

    function navigateGallery(direction) {
        updateGalleryImage(currentImageIndex + direction);
    }

    function changeImage(element, src) {
        var index = galleryImages.indexOf(src);
        if (index > -1) {
            updateGalleryImage(index);
        }
    }

    function openLightbox() {
        var counter = document.getElementById('lightboxCounter');
        if (counter) counter.innerText = (currentImageIndex + 1) + ' / ' + galleryImages.length;
        
        var lightboxImg = document.getElementById('lightboxImage');
        if (lightboxImg) {
            preloadGalleryImage(currentImageIndex).then(function() {
                lightboxImg.src = galleryImages[currentImageIndex];
            });
        }
        
        var modal = document.getElementById('lightboxModal');
        if (modal) modal.classList.add('show');
        preloadAdjacentImages();
        
        document.body.style.overflow = 'hidden'; // Arka plan kaydırmayı engelle
    }

    function closeLightbox() {
        var modal = document.getElementById('lightboxModal');
        if (modal) modal.classList.remove('show');
        
        document.body.style.overflow = ''; // Arka plan kaydırmayı serbest bırak
    }

    // Klavye kısayolları (ESC, Sol, Sağ)
    document.addEventListener('keydown', function(e) {
        var modal = document.getElementById('lightboxModal');
        if (modal && modal.classList.contains('show')) {
            if (e.key === 'ArrowRight') {
                navigateGallery(1);
            } else if (e.key === 'ArrowLeft') {
                navigateGallery(-1);
            } else if (e.key === 'Escape') {
                closeLightbox();
            }
        }
    });

    preloadGalleryImage(0);
    preloadAdjacentImages();
    preloadGalleryInBackground();
</script>
