@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - DefenceDB Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-logo">
                <i class="bi bi-shield-fill-check"></i>
                <h2>DefenceDB Admin</h2>
                <p>Yönetim paneline erişmek için giriş yapın</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="login-error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Error</span>
                </div>
            }

            <form method="post" asp-area="Admin" asp-controller="Account" asp-action="Login" class="login-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="form-group">
                    <label for="email">
                        <i class="bi bi-envelope-fill me-1"></i> E-posta Adresi
                    </label>
                    <input type="email" id="email" name="email" placeholder="admin@example.com" required autocomplete="email" autofocus />
                </div>

                <div class="form-group">
                    <label for="password">
                        <i class="bi bi-lock-fill me-1"></i> Şifre
                    </label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password" />
                </div>

                <div class="remember-row">
                    <input type="checkbox" id="rememberMe" name="rememberMe" value="true" />
                    <label for="rememberMe">Beni Hatırla</label>
                </div>

                <button type="submit" class="login-btn">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Giriş Yap
                </button>
            </form>

            <div class="text-center mt-4">
                <a href="/" class="text-decoration-none" style="color: var(--admin-text-muted); font-size: 0.8rem;">
                    <i class="bi bi-arrow-left me-1"></i> Ana Siteye Dön
                </a>
            </div>
        </div>
    </div>
</body>
</html>
