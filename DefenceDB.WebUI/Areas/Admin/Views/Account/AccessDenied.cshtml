@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Erişim Engellendi - DefenceDB Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="access-denied-wrapper">
        <div>
            <i class="bi bi-shield-fill-x access-denied-icon"></i>
            <h2 style="font-family: 'Outfit', sans-serif; font-weight: 700; color: var(--admin-text); margin-bottom: 12px;">
                Erişim Engellendi
            </h2>
            <p style="color: var(--admin-text-muted); font-size: 0.95rem; max-width: 400px; margin: 0 auto 28px;">
                Bu sayfaya erişim yetkiniz bulunmamaktadır. Yönetici ile iletişime geçin veya giriş sayfasına dönün.
            </p>
            <div class="d-flex gap-3 justify-content-center">
                <a href="@Url.Action("Login", "Account", new { area = "Admin" })" class="btn-admin-primary">
                    <i class="bi bi-box-arrow-in-right"></i> Giriş Sayfası
                </a>
                <a href="/" class="btn-admin-outline">
                    <i class="bi bi-house"></i> Ana Sayfa
                </a>
            </div>
        </div>
    </div>
</body>
</html>
