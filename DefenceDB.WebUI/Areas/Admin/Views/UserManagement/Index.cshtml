@model List<AppUser>
@{
    var userRoles = (Dictionary<string, IList<string>>)ViewBag.UserRoles;
    var allRoles = (List<AppRole>)ViewBag.AllRoles;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="font-family: 'Outfit', sans-serif; font-weight: 700; margin: 0;">
            <i class="bi bi-people-fill text-warning me-2"></i> Kullanıcı Yönetimi
        </h4>
        <p style="color: var(--admin-text-muted); font-size: 0.85rem; margin: 4px 0 0;">
            Kullanıcıları görüntüleyin, rol atayın veya silin.
        </p>
    </div>
    <a asp-action="CreateUser" class="btn-admin-primary">
        <i class="bi bi-person-plus-fill"></i> Yeni Kullanıcı
    </a>
</div>

<div class="table-wrapper">
    <div class="table-body">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Kullanıcı</th>
                        <th>E-posta</th>
                        <th>Rol</th>
                        <th>Kayıt Tarihi</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : new List<string>();
                        var currentRole = roles.FirstOrDefault() ?? "Rol Yok";
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--admin-accent), #d97706); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                        <i class="bi bi-person-fill" style="color: #0a0e1a; font-size: 0.9rem;"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight: 600;">@(user.FullName)</div>
                                        <small style="color: var(--admin-text-muted);">@@user.UserName</small>
                                    </div>
                                </div>
                            </td>
                            <td style="color: var(--admin-text-secondary);">@user.Email</td>
                            <td>
                                @if (currentRole == "Admin")
                                {
                                    <span class="admin-badge danger"><i class="bi bi-shield-fill-check"></i> Admin</span>
                                }
                                else if (currentRole == "Editor")
                                {
                                    <span class="admin-badge info"><i class="bi bi-pencil-square"></i> Editor</span>
                                }
                                else if (currentRole == "User")
                                {
                                    <span class="admin-badge active"><i class="bi bi-person"></i> User</span>
                                }
                                else
                                {
                                    <span class="admin-badge warning"><i class="bi bi-exclamation-circle"></i> @currentRole</span>
                                }
                            </td>
                            <td style="color: var(--admin-text-muted); font-size: 0.8rem;">
                                @user.CreatedAt.ToString("dd MMM yyyy")
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2 align-items-center">
                                    <!-- Role Change -->
                                    <form asp-action="ChangeRole" method="post" class="d-inline-flex align-items-center gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <select name="newRole" class="admin-form-control" style="width: 110px; padding: 6px 10px; font-size: 0.78rem;">
                                            @foreach (var role in allRoles)
                                            {
                                                <option value="@role.Name" selected="@(currentRole == role.Name)">@role.Name</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn-icon" title="Rolü Değiştir">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <!-- Delete -->
                                    <form asp-action="DeleteUser" method="post"
                                          onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn-icon danger" title="Sil">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
