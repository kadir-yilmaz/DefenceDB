<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DefenceDB Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css?v=5" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <span>DefenceDB</span>
            </div>
            <small class="sidebar-badge">ADMIN PANEL</small>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-section-title">ANA MENÜ</span>
                <a href="@Url.Action("Index", "Dashboard", new { area = "Admin" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
                <a href="@Url.Action("Index", "ProductManagement", new { area = "Admin" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProductManagement" ? "active" : "")">
                    <i class="bi bi-box-seam-fill"></i>
                    <span>Ürün Yönetimi</span>
                </a>
                <a href="@Url.Action("Index", "CategoryManagement", new { area = "Admin" })"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "CategoryManagement" ? "active" : "")">
                    <i class="bi bi-list-nested"></i>
                    <span>Kategori Yönetimi</span>
                </a>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-section">
                    <span class="nav-section-title">YÖNETİM</span>
                    <a href="@Url.Action("Index", "UserManagement", new { area = "Admin" })"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserManagement" ? "active" : "")">
                        <i class="bi bi-people-fill"></i>
                        <span>Kullanıcılar</span>
                    </a>
                </div>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user-info">
                <div class="user-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div class="user-details">
                    <span class="user-name">@User.Identity?.Name</span>
                    <span class="user-role">
                        @if (User.IsInRole("Admin"))
                        {
                            <span class="badge-role badge-admin">Admin</span>
                        }
                        else if (User.IsInRole("Editor"))
                        {
                            <span class="badge-role badge-editor">Editor</span>
                        }
                    </span>
                </div>
            </div>
            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout" title="Çıkış Yap">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
            
            <!-- Mobile Profile Dropdown -->
            <div class="mobile-profile-btn" onclick="toggleMobileProfile(event)">
                <i class="bi bi-person-fill"></i>
            </div>
            <div class="mobile-profile-dropdown" id="mobileProfileDropdown">
                <div class="mobile-profile-header">
                    <div class="mobile-profile-name">@User.Identity?.Name</div>
                    <span class="user-role">
                        @if (User.IsInRole("Admin"))
                        {
                            <span class="badge-role badge-admin">Admin</span>
                        }
                        else if (User.IsInRole("Editor"))
                        {
                            <span class="badge-role badge-editor">Editor</span>
                        }
                    </span>
                </div>
                <div class="mobile-profile-menu">
                    <a href="/" class="mobile-profile-item" target="_blank">
                        <i class="bi bi-globe2"></i>
                        <span>Siteyi Görüntüle</span>
                    </a>
                    <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" style="margin: 0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="mobile-profile-item danger">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Çıkış Yap</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="admin-main">
        <!-- Top Bar -->
        <header class="admin-topbar">
            <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <div class="topbar-left">
                <h5 class="topbar-title">@ViewData["Title"]</h5>
            </div>
            <div class="topbar-right">
            </div>
        </header>

        <!-- Page Content -->
        <main class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar toggle (sadece desktop için)
        function toggleSidebar() {
            if (window.innerWidth >= 992) {
                document.querySelector('.admin-sidebar').classList.toggle('collapsed');
                document.querySelector('.admin-main').classList.toggle('expanded');
            }
        }

        // Mobile profile dropdown toggle
        function toggleMobileProfile(event) {
            event.stopPropagation();
            const dropdown = document.getElementById('mobileProfileDropdown');
            dropdown.classList.toggle('show');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('mobileProfileDropdown');
            const profileBtn = document.querySelector('.mobile-profile-btn');
            
            if (dropdown && !dropdown.contains(event.target) && !profileBtn.contains(event.target)) {
                dropdown.classList.remove('show');
            }
        });

        // Mobilde sidebar her zaman görünür, toggle butonu gizli
        window.addEventListener('resize', function() {
            if (window.innerWidth < 992) {
                document.querySelector('.admin-sidebar').classList.remove('collapsed');
                document.querySelector('.admin-main').classList.remove('expanded');
            }
        });
    </script>
    @await Component.InvokeAsync("NToastNotify")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
