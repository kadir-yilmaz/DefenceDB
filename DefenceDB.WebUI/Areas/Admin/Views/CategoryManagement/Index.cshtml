@model IEnumerable<DefenceDB.EL.Models.Category>

@{
    ViewData["Title"] = "Kategori Yönetimi (Navbar)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="font-family: 'Outfit', sans-serif; font-weight: 700; margin: 0;">
            <i class="bi bi-list-nested text-warning me-2"></i> Kategori Yönetimi
        </h4>
        <p style="color: var(--admin-text-muted); font-size: 0.85rem; margin: 4px 0 0;">
            Navbar menüsünde gösterilecek ana kategorileri buradan düzenleyebilirsiniz.
        </p>
    </div>
    <span class="admin-badge info">@Model.Count() Ana Kategori</span>
</div>

<div class="table-wrapper">
    <div class="table-body">
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width: 10%;">#</th>
                        <th style="width: 30%;">Kategori Adı</th>
                        <th style="width: 15%;">İkon</th>
                        <th style="width: 15%;">Alt Kategori Sayısı</th>
                        <th style="width: 15%;">Ana Menüde Göster (Navbar)</th>
                        <th style="width: 15%;" class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model.OrderBy(c => c.SortOrder))
                    {
                        <tr>
                            <td>@cat.Id</td>
                            <td>
                                <div style="font-weight: 600;">@cat.Name</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(cat.IconClass))
                                {
                                    <i class="@cat.IconClass text-primary fs-5"></i>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <span class="admin-badge info">@cat.SubCategories.Count</span>
                            </td>
                            <td>
                                @if (cat.IsShowcase)
                                {
                                    <span class="admin-badge success"><i class="bi bi-check-circle-fill me-1"></i> Gösteriliyor</span>
                                }
                                else
                                {
                                    <span class="admin-badge secondary"><i class="bi bi-x-circle-fill me-1"></i> Gizli</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="ToggleShowcase" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    @if (cat.IsShowcase)
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Menüden Kaldır" style="border-radius: 8px;">
                                            <i class="bi bi-eye-slash-fill"></i> Gizle
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Menüye Ekle" style="border-radius: 8px;">
                                            <i class="bi bi-eye-fill"></i> Göster
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Kayıtlı kategori bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
